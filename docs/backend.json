{
  "entities": {
    "Exporter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exporter",
      "type": "object",
      "description": "Represents an exporter or producer.",
      "properties": {
        "exporterId": {
          "type": "string",
          "description": "Unique identifier for the exporter."
        },
        "name": {
          "type": "string",
          "description": "Name of the exporter/producer."
        },
        "type": {
          "type": "string",
          "description": "Type of exporter (e.g., exportador, productor_exportador)."
        }
      },
      "required": [
        "exporterId",
        "name",
        "type"
      ]
    },
    "Producer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Producer",
      "type": "object",
      "description": "Represents a producer.",
      "properties": {
        "producerId": {
          "type": "string",
          "description": "Unique identifier for the producer."
        },
        "shortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "name": {
          "type": "string",
          "description": "Full name of the producer."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N Producer)"
        }
      },
      "required": [
        "producerId",
        "shortName",
        "name",
        "exporterId"
      ]
    },
    "BinMaterial": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterial",
      "type": "object",
      "description": "Represents a bin or material.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Article code."
        },
        "name": {
          "type": "string",
          "description": "Product name."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N BinMaterial)"
        },
        "type": {
          "type": "string",
          "description": "Type of bin or material (e.g., bin, material)."
        }
      },
      "required": [
        "code",
        "name",
        "exporterId",
        "type"
      ]
    },
    "BinMaterialMovement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterialMovement",
      "type": "object",
      "description": "Records an entry or exit movement of bin materials.",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "entrada",
            "salida"
          ],
          "description": "The type of movement."
        },
        "document": {
          "type": "string",
          "description": "Document number for the movement."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the Exporter."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to the Producer."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "binMaterialId": {
                "type": "string"
              },
              "binMaterialCode": {
                "type": "string"
              },
              "binMaterialName": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              }
            },
            "required": [
              "binMaterialId",
              "binMaterialCode",
              "binMaterialName",
              "quantity"
            ]
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the movement."
        }
      },
      "required": [
        "type",
        "document",
        "exporterId",
        "producerId",
        "items",
        "createdAt"
      ]
    },
    "BinMaterialStock": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterialStock",
      "type": "object",
      "description": "Represents the current stock of a specific bin material for an exporter.",
      "properties": {
        "binMaterialId": {
          "type": "string",
          "description": "Reference to the BinMaterial."
        },
        "binMaterialCode": {
          "type": "string",
          "description": "Denormalized code for easier querying."
        },
        "binMaterialName": {
          "type": "string",
          "description": "Denormalized name for easier display."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the Exporter."
        },
        "quantity": {
          "type": "number",
          "description": "Current quantity in stock."
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last stock update."
        }
      },
      "required": [
        "binMaterialId",
        "binMaterialCode",
        "binMaterialName",
        "exporterId",
        "quantity",
        "lastUpdatedAt"
      ]
    },
    "OtherClient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OtherClient",
      "type": "object",
      "description": "Represents a client other than exporters or producers.",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Unique identifier for the client."
        },
        "name": {
          "type": "string",
          "description": "Name of the client."
        },
        "type": {
          "type": "string",
          "description": "Type of client (e.g., embalajes, frio_hortofruticola)."
        },
        "unit": {
          "type": "string",
          "description": "Business unit associated with the client.",
          "enum": [
            "Bins",
            "Pallets"
          ]
        }
      },
      "required": [
        "clientId",
        "name",
        "type",
        "unit"
      ]
    },
    "PackagingMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PackagingMaster",
      "type": "object",
      "description": "Represents a packaging material.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Article code."
        },
        "name": {
          "type": "string",
          "description": "Product name."
        },
        "clientId": {
          "type": "string",
          "description": "Reference to OtherClient. (Relationship: OtherClient 1:N PackagingMaster)"
        }
      },
      "required": [
        "code",
        "name",
        "clientId"
      ]
    },
    "Packing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Packing",
      "type": "object",
      "description": "Represents a packing material associated with an exporter.",
      "properties": {
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N Packing)"
        },
        "name": {
          "type": "string",
          "description": "Name of the packing material."
        }
      },
      "required": [
        "exporterId",
        "name"
      ]
    },
    "UserMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserMaster",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "userName": {
          "type": "string",
          "description": "User's name."
        },
        "profileId": {
          "type": "string",
          "description": "Reference to Profile. (Relationship: Profile 1:N UserMaster)"
        }
      },
      "required": [
        "userName",
        "profileId"
      ]
    },
    "Profile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Profile",
      "type": "object",
      "description": "Represents a user profile with access permissions.",
      "properties": {
        "profileId": {
          "type": "string",
          "description": "Unique identifier for the profile."
        },
        "name": {
          "type": "string",
          "description": "Name of the profile."
        },
        "modulesAccess": {
          "type": "array",
          "description": "List of module names the profile has access to.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "profileId",
        "name",
        "modulesAccess"
      ]
    },
    "ReceptionLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ReceptionLot",
      "type": "object",
      "description": "Represents a reception lot of fruit.",
      "properties": {
        "lotId": {
          "type": "string",
          "description": "Unique identifier for the lot."
        },
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier (e.g., PROD-DOC123)."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the selected Exporter."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to the selected Producer."
        },
        "document": {
          "type": "string",
          "description": "Document number for the lot."
        },
        "variety": {
          "type": "string",
          "description": "Variety of the fruit."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in the lot."
        },
        "toteCount": {
          "type": "number",
          "description": "Number of totes in the lot."
        },
        "emptyTotes": {
          "type": "number",
          "description": "Optional number of empty totes."
        },
        "status": {
          "type": "string",
          "description": "Status of the lot (e.g., 'Pendiente de Peso')."
        },
        "totalWeight": {
          "type": "number",
          "description": "Total weight of the lot."
        },
        "preHydroTemp": {
          "type": "number",
          "description": "Pre-Hidrocooler temperature."
        },
        "postHydroTemp": {
          "type": "number",
          "description": "Post-Hidrocooler temperature."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot was created."
        }
      },
      "required": [
        "displayLotId",
        "exporterId",
        "producerId",
        "document",
        "variety",
        "binCount",
        "toteCount",
        "status",
        "createdAt"
      ]
    },
    "HidrocoolerLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HidrocoolerLot",
      "type": "object",
      "description": "Represents a lot in the hidrocooler process.",
      "properties": {
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier, same as in ReceptionLot."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in the lot."
        },
        "status": {
          "type": "string",
          "description": "Status of the lot in the hidrocooler (e.g., 'Pendiente de Pre-Hidro', 'En Proceso', 'Finalizado')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot entered the hidrocooler process."
        }
      },
      "required": [
        "displayLotId",
        "producerShortName",
        "binCount",
        "status",
        "createdAt"
      ]
    },
    "ProcessingLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProcessingLot",
      "type": "object",
      "description": "Represents a fraction of a lot being processed in a hidrocooler.",
      "properties": {
        "originalLotId": {
          "type": "string",
          "description": "The ID of the original lot in hidrocoolerLots."
        },
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in this processing fraction."
        },
        "hidrocooler": {
          "type": "string",
          "description": "The hidrocooler unit used (e.g., 'HIDROCOOLER 1')."
        },
        "status": {
          "type": "string",
          "enum": [
            "En Proceso",
            "Finalizado"
          ],
          "description": "Status of the processing fraction."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when processing started."
        }
      },
      "required": [
        "originalLotId",
        "displayLotId",
        "producerShortName",
        "binCount",
        "hidrocooler",
        "status",
        "createdAt"
      ]
    },
    "ChamberLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChamberLot",
      "type": "object",
      "description": "Represents a lot stored in a cooling chamber.",
      "properties": {
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the selected Exporter."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in this portion of the lot."
        },
        "variety": {
          "type": "string",
          "description": "Variety of the fruit."
        },
        "hidrocooler": {
          "type": "string",
          "description": "The hidrocooler unit used for processing."
        },
        "chamberId": {
          "type": "string",
          "description": "The identifier of the chamber where the lot is stored."
        },
        "coordinate": {
            "type": "string",
            "description": "The specific coordinate within the chamber (e.g., 'A1')."
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente por Almacenar", "Almacenado", "Despachado"],
          "description": "Status of the lot in the chamber."
        },
        "storedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot was moved to the chamber module."
        }
      },
      "required": [
        "displayLotId",
        "exporterId",
        "producerShortName",
        "binCount",
        "variety",
        "hidrocooler",
        "status",
        "storedAt"
      ]
    },
    "Chamber": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Chamber",
      "type": "object",
      "description": "Configuration for a single cooling chamber.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "rows": { "type": "array", "items": { "type": "number" } }
      },
      "required": ["id", "name", "capacity", "columns", "rows"]
    },
    "Dispatch": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Dispatch",
      "type": "object",
      "description": "Represents a dispatch of fruit to a client.",
      "properties": {
        "exporterId": {
          "type": "string",
          "description": "The ID of the exporter client."
        },
        "exporterName": {
          "type": "string",
          "description": "The name of the exporter client."
        },
        "packingId": {
          "type": "string",
          "description": "Reference to Packing (optional)."
        },
        "totalBins": {
          "type": "number",
          "description": "Total number of bins in the dispatch."
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente de Salida", "Completado"],
          "description": "Status of the dispatch."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the dispatch was created."
        },
        "bins": {
          "type": "array",
          "description": "List of bins included in the dispatch.",
          "items": {
            "type": "object",
            "properties": {
              "chamberLotId": { "type": "string" },
              "displayLotId": { "type": "string" },
              "chamberId": { "type": "string" },
              "coordinate": { "type": "string" },
              "binCount": { "type": "number" }
            },
            "required": ["chamberLotId", "displayLotId", "chamberId", "coordinate", "binCount"]
          }
        }
      },
      "required": [
        "exporterId",
        "exporterName",
        "totalBins",
        "status",
        "createdAt",
        "bins"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/exporters/{exporterId}",
        "definition": {
          "entityName": "Exporter",
          "schema": {
            "$ref": "#/backend/entities/Exporter"
          },
          "description": "Stores exporter data.  exporterId is used as the document ID.",
          "params": [
            {
              "name": "exporterId",
              "description": "The unique identifier for the exporter."
            }
          ]
        }
      },
      {
        "path": "/producers/{producerId}",
        "definition": {
          "entityName": "Producer",
          "schema": {
            "$ref": "#/backend/entities/Producer"
          },
          "description": "Stores producer data.  producerId is used as the document ID. Includes exporterId for reference.",
          "params": [
            {
              "name": "producerId",
              "description": "The unique identifier for the producer."
            }
          ]
        }
      },
      {
        "path": "/binMaterials/{binMaterialId}",
        "definition": {
          "entityName": "BinMaterial",
          "schema": {
            "$ref": "#/backend/entities/BinMaterial"
          },
          "description": "Stores bin and material data. A generated ID will be used, but the code and exporterId fields are present for querying and relationships.",
          "params": [
            {
              "name": "binMaterialId",
              "description": "The unique identifier for the bin material."
            }
          ]
        }
      },
       {
        "path": "/binMaterialMovements/{movementId}",
        "definition": {
          "entityName": "BinMaterialMovement",
          "schema": { "$ref": "#/backend/entities/BinMaterialMovement" },
          "description": "Stores a log of all bin and material movements (entries/exits).",
           "params": [
            {
              "name": "movementId",
              "description": "The unique identifier for the movement log."
            }
          ]
        }
      },
      {
        "path": "/binMaterialStock/{stockId}",
        "definition": {
          "entityName": "BinMaterialStock",
          "schema": { "$ref": "#/backend/entities/BinMaterialStock" },
          "description": "Stores the current aggregated stock for each material, per exporter. Document ID is a composite key or a generated one.",
           "params": [
            {
              "name": "stockId",
              "description": "The unique identifier for the stock record."
            }
          ]
        }
      },
      {
        "path": "/otherClients/{otherClientId}",
        "definition": {
          "entityName": "OtherClient",
          "schema": {
            "$ref": "#/backend/entities/OtherClient"
          },
          "description": "Stores data for other clients. otherClientId is used as the document ID.",
          "params": [
            {
              "name": "otherClientId",
              "description": "The unique identifier for the other client."
            }
          ]
        }
      },
      {
        "path": "/packagingMaster/{packagingMasterId}",
        "definition": {
          "entityName": "PackagingMaster",
          "schema": {
            "$ref": "#/backend/entities/PackagingMaster"
          },
          "description": "Stores packaging material data. A generated ID will be used, but code and clientId fields are present for querying and relationships.",
          "params": [
            {
              "name": "packagingMasterId",
              "description": "The unique identifier for the packaging master."
            }
          ]
        }
      },
       {
        "path": "/packings/{packingId}",
        "definition": {
          "entityName": "Packing",
          "schema": {
            "$ref": "#/backend/entities/Packing"
          },
          "description": "Stores packing data related to an exporter.",
          "params": [
            {
              "name": "packingId",
              "description": "The unique identifier for the packing."
            }
          ]
        }
      },
      {
        "path": "/usersMaster/{userMasterId}",
        "definition": {
          "entityName": "UserMaster",
          "schema": {
            "$ref": "#/backend/entities/UserMaster"
          },
          "description": "Stores user data. A generated ID will be used. Includes profileId for role-based access control.",
          "params": [
            {
              "name": "userMasterId",
              "description": "The unique identifier for the user master."
            }
          ]
        }
      },
      {
        "path": "/profiles/{profileId}",
        "definition": {
          "entityName": "Profile",
          "schema": {
            "$ref": "#/backend/entities/Profile"
          },
          "description": "Stores profile data. profileId is used as the document ID. Defines access permissions based on modules.",
          "params": [
            {
              "name": "profileId",
              "description": "The unique identifier for the profile."
            }
          ]
        }
      },
      {
        "path": "/receptionLots/{lotId}",
        "definition": {
          "entityName": "ReceptionLot",
          "schema": {
            "$ref": "#/backend/entities/ReceptionLot"
          },
          "description": "Stores reception lot data. A generated ID will be used.",
          "params": [
            {
              "name": "lotId",
              "description": "The unique identifier for the reception lot."
            }
          ]
        }
      },
      {
        "path": "/hidrocoolerLots/{hidrocoolerLotId}",
        "definition": {
          "entityName": "HidrocoolerLot",
          "schema": {
            "$ref": "#/backend/entities/HidrocoolerLot"
          },
          "description": "Stores lots that are pending to enter the hidrocooler process. A generated ID will be used.",
          "params": [
            {
              "name": "hidrocoolerLotId",
              "description": "The unique identifier for the hidrocooler lot."
            }
          ]
        }
      },
      {
        "path": "/processingLots/{processingLotId}",
        "definition": {
          "entityName": "ProcessingLot",
          "schema": {
            "$ref": "#/backend/entities/ProcessingLot"
          },
          "description": "Stores fractions of lots that are actively being processed in a hidrocooler. A generated ID will be used.",
          "params": [
            {
              "name": "processingLotId",
              "description": "The unique identifier for the processing lot."
            }
          ]
        }
      },
      {
        "path": "/chamberLots/{chamberLotId}",
        "definition": {
          "entityName": "ChamberLot",
          "schema": {
            "$ref": "#/backend/entities/ChamberLot"
          },
          "description": "Stores lot fractions that have been moved into a cooling chamber.",
          "params": [
            {
              "name": "chamberLotId",
              "description": "The unique identifier for the lot in the chamber."
            }
          ]
        }
      },
      {
        "path": "/dispatches/{dispatchId}",
        "definition": {
          "entityName": "Dispatch",
          "schema": {
            "$ref": "#/backend/entities/Dispatch"
          },
          "description": "Stores dispatch records. A generated ID will be used.",
          "params": [
            {
              "name": "dispatchId",
              "description": "The unique identifier for the dispatch."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore data structure is designed to support the FrigoManager application, focusing on master data management and related operational modules.  The design prioritizes authorization independence and easy debugging. Each master data entity (Exporter, Producer, BinMaterial, OtherClient, PackagingMaster, UserMaster, Profile) is stored in its own top-level collection. This Structural Segregation ensures a homogeneous security posture for each entity type. The `exporterId`, `producerId`, `clientId`, and `profileId` fields are used as logical keys to relate data between modules, but are not used for access control.  User authentication is handled by Firebase Auth, and user roles can be managed through the `profiles` and `usersMaster` collections.  Since user roles are managed in the database, no custom claims are required. This design inherently supports QAPs because list operations are secured by collection-level rules, and all documents within a collection share the same security requirements.  There are no hierarchical dependencies, so complex filtering within rules is avoided."
  }
}
