{
  "entities": {
    "Exporter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exporter",
      "type": "object",
      "description": "Represents an exporter or producer.",
      "properties": {
        "exporterId": {
          "type": "string",
          "description": "Unique identifier for the exporter."
        },
        "name": {
          "type": "string",
          "description": "Name of the exporter/producer."
        },
        "type": {
          "type": "string",
          "description": "Type of exporter (e.g., exportador, productor_exportador)."
        }
      },
      "required": [
        "exporterId",
        "name",
        "type"
      ]
    },
    "Producer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Producer",
      "type": "object",
      "description": "Represents a producer.",
      "properties": {
        "producerId": {
          "type": "string",
          "description": "Unique identifier for the producer."
        },
        "shortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "name": {
          "type": "string",
          "description": "Full name of the producer."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N Producer)"
        }
      },
      "required": [
        "producerId",
        "shortName",
        "name",
        "exporterId"
      ]
    },
    "BinMaterial": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterial",
      "type": "object",
      "description": "Represents a bin or material.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Article code."
        },
        "name": {
          "type": "string",
          "description": "Product name."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N BinMaterial)"
        },
        "type": {
          "type": "string",
          "description": "Type of bin or material (e.g., bin, material)."
        }
      },
      "required": [
        "code",
        "name",
        "exporterId",
        "type"
      ]
    },
    "OtherClient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OtherClient",
      "type": "object",
      "description": "Represents a client other than exporters or producers.",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Unique identifier for the client."
        },
        "name": {
          "type": "string",
          "description": "Name of the client."
        },
        "type": {
          "type": "string",
          "description": "Type of client (e.g., embalajes, frio_hortofruticola)."
        }
      },
      "required": [
        "clientId",
        "name",
        "type"
      ]
    },
    "PackagingMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PackagingMaster",
      "type": "object",
      "description": "Represents a packaging material.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Article code."
        },
        "name": {
          "type": "string",
          "description": "Product name."
        },
        "clientId": {
          "type": "string",
          "description": "Reference to OtherClient. (Relationship: OtherClient 1:N PackagingMaster)"
        }
      },
      "required": [
        "code",
        "name",
        "clientId"
      ]
    },
    "UserMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserMaster",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "userName": {
          "type": "string",
          "description": "User's name."
        },
        "profileId": {
          "type": "string",
          "description": "Reference to Profile. (Relationship: Profile 1:N UserMaster)"
        }
      },
      "required": [
        "userName",
        "profileId"
      ]
    },
    "Profile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Profile",
      "type": "object",
      "description": "Represents a user profile with access permissions.",
      "properties": {
        "profileId": {
          "type": "string",
          "description": "Unique identifier for the profile."
        },
        "name": {
          "type": "string",
          "description": "Name of the profile."
        },
        "modulesAccess": {
          "type": "array",
          "description": "List of module names the profile has access to.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "profileId",
        "name",
        "modulesAccess"
      ]
    },
    "ReceptionLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ReceptionLot",
      "type": "object",
      "description": "Represents a reception lot of fruit.",
      "properties": {
        "lotId": {
          "type": "string",
          "description": "Unique identifier for the lot."
        },
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier (e.g., PROD-DOC123)."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the selected Exporter."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to the selected Producer."
        },
        "document": {
          "type": "string",
          "description": "Document number for the lot."
        },
        "variety": {
          "type": "string",
          "description": "Variety of the fruit."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in the lot."
        },
        "toteCount": {
          "type": "number",
          "description": "Number of totes in the lot."
        },
        "emptyTotes": {
          "type": "number",
          "description": "Optional number of empty totes."
        },
        "status": {
          "type": "string",
          "description": "Status of the lot (e.g., 'Pendiente de Peso')."
        },
        "totalWeight": {
          "type": "number",
          "description": "Total weight of the lot."
        },
        "preHydroTemp": {
          "type": "number",
          "description": "Pre-Hidrocooler temperature."
        },
        "postHydroTemp": {
          "type": "number",
          "description": "Post-Hidrocooler temperature."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot was created."
        }
      },
      "required": [
        "displayLotId",
        "exporterId",
        "producerId",
        "document",
        "variety",
        "binCount",
        "toteCount",
        "status",
        "createdAt"
      ]
    },
    "HidrocoolerLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HidrocoolerLot",
      "type": "object",
      "description": "Represents a lot in the hidrocooler process.",
      "properties": {
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier, same as in ReceptionLot."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in the lot."
        },
        "status": {
          "type": "string",
          "description": "Status of the lot in the hidrocooler (e.g., 'Pendiente de Pre-Hidro', 'En Proceso', 'Finalizado')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot entered the hidrocooler process."
        }
      },
      "required": [
        "displayLotId",
        "producerShortName",
        "binCount",
        "status",
        "createdAt"
      ]
    },
    "ProcessingLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProcessingLot",
      "type": "object",
      "description": "Represents a fraction of a lot being processed in a hidrocooler.",
      "properties": {
        "originalLotId": {
          "type": "string",
          "description": "The ID of the original lot in hidrocoolerLots."
        },
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in this processing fraction."
        },
        "hidrocooler": {
          "type": "string",
          "description": "The hidrocooler unit used (e.g., 'HIDROCOOLER 1')."
        },
        "status": {
          "type": "string",
          "enum": [
            "En Proceso",
            "Finalizado"
          ],
          "description": "Status of the processing fraction."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when processing started."
        }
      },
      "required": [
        "originalLotId",
        "displayLotId",
        "producerShortName",
        "binCount",
        "hidrocooler",
        "status",
        "createdAt"
      ]
    },
    "ChamberLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChamberLot",
      "type": "object",
      "description": "Represents a lot stored in a cooling chamber.",
      "properties": {
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in this portion of the lot."
        },
        "hidrocooler": {
          "type": "string",
          "description": "The hidrocooler unit used for processing."
        },
        "chamberId": {
          "type": "string",
          "description": "The identifier of the chamber where the lot is stored."
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente por Almacenar", "Almacenado"],
          "description": "Status of the lot in the chamber."
        },
        "storedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot was moved to the chamber module."
        }
      },
      "required": [
        "displayLotId",
        "producerShortName",
        "binCount",
        "hidrocooler",
        "status",
        "storedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/exporters/{exporterId}",
        "definition": {
          "entityName": "Exporter",
          "schema": {
            "$ref": "#/backend/entities/Exporter"
          },
          "description": "Stores exporter data.  exporterId is used as the document ID.",
          "params": [
            {
              "name": "exporterId",
              "description": "The unique identifier for the exporter."
            }
          ]
        }
      },
      {
        "path": "/producers/{producerId}",
        "definition": {
          "entityName": "Producer",
          "schema": {
            "$ref": "#/backend/entities/Producer"
          },
          "description": "Stores producer data.  producerId is used as the document ID. Includes exporterId for reference.",
          "params": [
            {
              "name": "producerId",
              "description": "The unique identifier for the producer."
            }
          ]
        }
      },
      {
        "path": "/binMaterials/{binMaterialId}",
        "definition": {
          "entityName": "BinMaterial",
          "schema": {
            "$ref": "#/backend/entities/BinMaterial"
          },
          "description": "Stores bin and material data. A generated ID will be used, but the code and exporterId fields are present for querying and relationships.",
          "params": [
            {
              "name": "binMaterialId",
              "description": "The unique identifier for the bin material."
            }
          ]
        }
      },
      {
        "path": "/otherClients/{otherClientId}",
        "definition": {
          "entityName": "OtherClient",
          "schema": {
            "$ref": "#/backend/entities/OtherClient"
          },
          "description": "Stores data for other clients. otherClientId is used as the document ID.",
          "params": [
            {
              "name": "otherClientId",
              "description": "The unique identifier for the other client."
            }
          ]
        }
      },
      {
        "path": "/packagingMaster/{packagingMasterId}",
        "definition": {
          "entityName": "PackagingMaster",
          "schema": {
            "$ref": "#/backend/entities/PackagingMaster"
          },
          "description": "Stores packaging material data. A generated ID will be used, but code and clientId fields are present for querying and relationships.",
          "params": [
            {
              "name": "packagingMasterId",
              "description": "The unique identifier for the packaging master."
            }
          ]
        }
      },
      {
        "path": "/usersMaster/{userMasterId}",
        "definition": {
          "entityName": "UserMaster",
          "schema": {
            "$ref": "#/backend/entities/UserMaster"
          },
          "description": "Stores user data. A generated ID will be used. Includes profileId for role-based access control.",
          "params": [
            {
              "name": "userMasterId",
              "description": "The unique identifier for the user master."
            }
          ]
        }
      },
      {
        "path": "/profiles/{profileId}",
        "definition": {
          "entityName": "Profile",
          "schema": {
            "$ref": "#/backend/entities/Profile"
          },
          "description": "Stores profile data. profileId is used as the document ID. Defines access permissions based on modules.",
          "params": [
            {
              "name": "profileId",
              "description": "The unique identifier for the profile."
            }
          ]
        }
      },
      {
        "path": "/receptionLots/{lotId}",
        "definition": {
          "entityName": "ReceptionLot",
          "schema": {
            "$ref": "#/backend/entities/ReceptionLot"
          },
          "description": "Stores reception lot data. A generated ID will be used.",
          "params": [
            {
              "name": "lotId",
              "description": "The unique identifier for the reception lot."
            }
          ]
        }
      },
      {
        "path": "/hidrocoolerLots/{hidrocoolerLotId}",
        "definition": {
          "entityName": "HidrocoolerLot",
          "schema": {
            "$ref": "#/backend/entities/HidrocoolerLot"
          },
          "description": "Stores lots that are pending to enter the hidrocooler process. A generated ID will be used.",
          "params": [
            {
              "name": "hidrocoolerLotId",
              "description": "The unique identifier for the hidrocooler lot."
            }
          ]
        }
      },
      {
        "path": "/processingLots/{processingLotId}",
        "definition": {
          "entityName": "ProcessingLot",
          "schema": {
            "$ref": "#/backend/entities/ProcessingLot"
          },
          "description": "Stores fractions of lots that are actively being processed in a hidrocooler. A generated ID will be used.",
          "params": [
            {
              "name": "processingLotId",
              "description": "The unique identifier for the processing lot."
            }
          ]
        }
      },
      {
        "path": "/chamberLots/{chamberLotId}",
        "definition": {
          "entityName": "ChamberLot",
          "schema": {
            "$ref": "#/backend/entities/ChamberLot"
          },
          "description": "Stores lot fractions that have been moved into a cooling chamber.",
          "params": [
            {
              "name": "chamberLotId",
              "description": "The unique identifier for the lot in the chamber."
            }
          ]
        }
      }
    ],
    "reasoning": "The Firestore data structure is designed to support the FrigoManager application, focusing on master data management and related operational modules.  The design prioritizes authorization independence and easy debugging. Each master data entity (Exporter, Producer, BinMaterial, OtherClient, PackagingMaster, UserMaster, Profile) is stored in its own top-level collection. This Structural Segregation ensures a homogeneous security posture for each entity type. The `exporterId`, `producerId`, `clientId`, and `profileId` fields are used as logical keys to relate data between modules, but are not used for access control.  User authentication is handled by Firebase Auth, and user roles can be managed through the `profiles` and `usersMaster` collections.  Since user roles are managed in the database, no custom claims are required. This design inherently supports QAPs because list operations are secured by collection-level rules, and all documents within a collection share the same security requirements.  There are no hierarchical dependencies, so complex filtering within rules is avoided."
  }
}