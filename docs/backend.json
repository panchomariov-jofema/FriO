{
  "entities": {
    "Exporter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Exporter",
      "type": "object",
      "description": "Represents an exporter or producer.",
      "properties": {
        "exporterId": {
          "type": "string",
          "description": "Unique identifier for the exporter."
        },
        "name": {
          "type": "string",
          "description": "Name of the exporter/producer."
        },
        "type": {
          "type": "string",
          "description": "Type of exporter (e.g., exportador, productor_exportador)."
        }
      },
      "required": [
        "exporterId",
        "name",
        "type"
      ]
    },
    "Producer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Producer",
      "type": "object",
      "description": "Represents a producer.",
      "properties": {
        "producerId": {
          "type": "string",
          "description": "Unique identifier for the producer."
        },
        "shortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "name": {
          "type": "string",
          "description": "Full name of the producer."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N Producer)"
        },
        "rut": {
          "type": "string",
          "description": "RUT of the producer."
        },
        "razon_social": {
          "type": "string",
          "description": "Legal name of the producer."
        },
        "giro": {
          "type": "string",
          "description": "Business activity of the producer."
        },
        "direccion": {
          "type": "string",
          "description": "Address of the producer."
        },
        "comuna": {
          "type": "string",
          "description": "Comuna (municipality) of the producer."
        },
        "ciudad": {
          "type": "string",
          "description": "City of the producer."
        }
      },
      "required": [
        "producerId",
        "shortName",
        "name",
        "exporterId"
      ]
    },
    "BinMaterial": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterial",
      "type": "object",
      "description": "Represents a bin or material.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Article code."
        },
        "name": {
          "type": "string",
          "description": "Product name."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N BinMaterial)"
        },
        "type": {
          "type": "string",
          "description": "Type of bin or material (e.g., bin, material)."
        }
      },
      "required": [
        "code",
        "name",
        "exporterId",
        "type"
      ]
    },
    "BinMaterialMovement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterialMovement",
      "type": "object",
      "description": "Records an entry or exit movement of bin materials.",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "entrada",
            "salida"
          ],
          "description": "The type of movement."
        },
        "document": {
          "type": "string",
          "description": "Document number for the movement."
        },
        "driverName": {
          "type": "string",
          "description": "Name of the driver."
        },
        "driverRUT": {
          "type": "string",
          "description": "RUT of the driver."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the Exporter."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to the Producer."
        },
        "packingId": {
          "type": "string",
          "description": "Reference to Packing (optional)."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "binMaterialId": {
                "type": "string"
              },
              "binMaterialCode": {
                "type": "string"
              },
              "binMaterialName": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              }
            },
            "required": [
              "binMaterialId",
              "binMaterialCode",
              "binMaterialName",
              "quantity"
            ]
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the movement."
        },
        "observation": {
          "type": "string",
          "description": "Optional observation about the movement, e.g., 'Despacho Directo'."
        }
      },
      "required": [
        "type",
        "document",
        "driverName",
        "driverRUT",
        "exporterId",
        "producerId",
        "items",
        "createdAt"
      ]
    },
    "BinMaterialStock": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "BinMaterialStock",
      "type": "object",
      "description": "Represents the current stock of a specific bin material for an exporter.",
      "properties": {
        "binMaterialId": {
          "type": "string",
          "description": "Reference to the BinMaterial."
        },
        "binMaterialCode": {
          "type": "string",
          "description": "Denormalized code for easier querying."
        },
        "binMaterialName": {
          "type": "string",
          "description": "Denormalized name for easier display."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the Exporter."
        },
        "quantity": {
          "type": "number",
          "description": "Current quantity in stock."
        },
        "lastUpdatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last stock update."
        }
      },
      "required": [
        "binMaterialId",
        "binMaterialCode",
        "binMaterialName",
        "exporterId",
        "quantity",
        "lastUpdatedAt"
      ]
    },
    "OtherClient": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OtherClient",
      "type": "object",
      "description": "Represents a client other than exporters or producers.",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Unique identifier for the client."
        },
        "name": {
          "type": "string",
          "description": "Name of the client."
        },
        "type": {
          "type": "string",
          "description": "Type of client (e.g., embalajes, frio_hortofruticola, fruta).",
           "enum": [
            "embalaje",
            "frio_hortofruticola",
            "fruta"
          ]
        },
        "unit": {
          "type": "string",
          "description": "Business unit associated with the client.",
          "enum": [
            "Bins",
            "Pallets"
          ]
        }
      },
      "required": [
        "clientId",
        "name",
        "type",
        "unit"
      ]
    },
    "PackagingMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PackagingMaster",
      "type": "object",
      "description": "Represents a packaging material.",
      "properties": {
        "code": {
          "type": "string",
          "description": "Article code."
        },
        "name": {
          "type": "string",
          "description": "Product name."
        },
        "clientId": {
          "type": "string",
          "description": "Reference to OtherClient. (Relationship: OtherClient 1:N PackagingMaster)"
        }
      },
      "required": [
        "code",
        "name",
        "clientId"
      ]
    },
    "PackagingReception": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PackagingReception",
      "description": "Records the reception of packaging materials on pallets.",
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "Reference to the 'OtherClient' providing the packaging."
        },
        "clientName": {
          "type": "string",
          "description": "Denormalized name of the client for display purposes."
        },
        "document": {
          "type": "string",
          "description": "The reception document number (e.g., shipping guide)."
        },
        "items": {
          "type": "array",
          "description": "List of packaging materials and their quantities received in this lot.",
          "items": {
            "type": "object",
            "properties": {
              "packagingMasterId": { "type": "string" },
              "packagingMasterCode": { "type": "string" },
              "packagingMasterName": { "type": "string" },
              "palletCount": { "type": "number" },
              "status": {
                "type": "string",
                "enum": ["Pendiente de almacenar", "Almacenado"],
                "description": "The status of this specific item in the lot."
              },
              "storageLocation": {
                "type": "object",
                "properties": {
                  "warehouse": { "type": "string" },
                  "aisle": { "type": "string" }
                }
              },
               "storedAt": {
                  "type": "string",
                  "format": "date-time"
                }
            },
            "required": ["packagingMasterId", "packagingMasterName", "palletCount", "status"]
          }
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente de almacenar", "Parcialmente Almacenado", "Almacenado"],
          "description": "The overall status of the reception lot."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
         "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["clientId", "clientName", "document", "items", "status", "createdAt"]
    },
     "OtherFruitReception": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OtherFruitReception",
      "description": "Records the reception of fruit from 'Other Clients' (type: fruta).",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "Reference to the 'OtherClient'." },
        "clientName": { "type": "string" },
        "displayLotId": { "type": "string", "description": "User-friendly lot identifier."},
        "unit": { "type": "string", "enum": ["Bins", "Pallets"] },
        "document": { "type": "string", "description": "Reception document number." },
        "temperature": {
          "type": "number",
          "description": "Optional temperature reading at reception."
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "clientLotId": {
                "type": "string",
                "description": "The client's own lot identifier for their traceability."
              },
              "productCode": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "weight": { "type": "number", "description": "Weight of the items in kilograms." },
              "status": { "type": "string", "enum": ["Pendiente de almacenar", "Almacenado"] },
              "storageLocation": {
                "type": "object",
                "properties": {
                  "chamberId": { "type": "string" },
                  "coordinate": { "type": "string" }
                }
              },
              "storedAt": { "type": "string", "format": "date-time" }
            },
            "required": ["productCode", "productName", "quantity", "status"]
          }
        },
        "status": { "type": "string", "enum": ["Pendiente de almacenar", "Parcialmente Almacenado", "Almacenado"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "clientName", "unit", "document", "items", "status", "createdAt"]
    },
    "PackagingMovement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PackagingMovement",
      "description": "Records a movement (entry or exit) of packaging materials.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["entrada", "salida"],
          "description": "The type of movement."
        },
        "clientId": {
          "type": "string",
          "description": "Reference to the 'OtherClient'."
        },
        "document": {
          "type": "string",
          "description": "Document number for the movement (e.g., shipping guide, consumption voucher)."
        },
        "items": {
          "type": "array",
          "description": "List of packaging materials and their quantities moved.",
          "items": {
            "type": "object",
            "properties": {
              "packagingMasterId": { "type": "string" },
              "packagingMasterCode": { "type": "string" },
              "packagingMasterName": { "type": "string" },
              "palletCount": { "type": "number" }
            },
            "required": ["packagingMasterId", "packagingMasterCode", "packagingMasterName", "palletCount"]
          }
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente de Picking", "Completado"],
          "description": "The status of the exit movement."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["type", "clientId", "document", "items", "createdAt", "status"]
    },
     "OtherFruitMovement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OtherFruitMovement",
      "description": "Records a movement (entry or exit) of fruit from other clients.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["entrada", "salida"],
          "description": "The type of movement."
        },
        "clientId": { "type": "string", "description": "Reference to the 'OtherClient'." },
        "clientName": { "type": "string" },
        "unit": { "type": "string", "enum": ["Bins", "Pallets"] },
        "document": { "type": "string", "description": "Document number for the movement." },
        "destinationClientName": { "type": "string", "description": "Name of the final destination client." },
        "destinationClientRUT": { "type": "string", "description": "RUT of the final destination client." },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productCode": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "weight": { "type": "number", "description": "Weight of the items in kilograms." },
              "clientLotId": { "type": "string" }
            },
            "required": ["productCode", "productName", "quantity"]
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente de Picking", "Completado"],
          "description": "The status of the exit movement, used for the picking process."
        },
        "locations": {
          "type": "array",
          "description": "Detailed list of items and their specific locations to be picked.",
          "items": {
            "type": "object",
            "properties": {
              "receptionId": { "type": "string" },
              "itemIndex": { "type": "number" },
              "quantity": { "type": "number" },
              "unit": { "type": "string", "enum": ["Bins", "Pallets"] },
              "productName": { "type": "string" },
              "clientLotId": { "type": "string" },
              "location": {
                "type": "object",
                "properties": {
                  "chamberId": { "type": "string" },
                  "coordinate": { "type": "string" }
                },
                "required": ["chamberId", "coordinate"]
              }
            },
            "required": ["receptionId", "itemIndex", "quantity", "unit", "productName", "location"]
          }
        }
      },
      "required": ["type", "clientId", "clientName", "unit", "items", "createdAt"]
    },
    "Packing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Packing",
      "type": "object",
      "description": "Represents a packing material associated with an exporter.",
      "properties": {
        "exporterId": {
          "type": "string",
          "description": "Reference to Exporter. (Relationship: Exporter 1:N Packing)"
        },
        "name": {
          "type": "string",
          "description": "Name of the packing material."
        }
      },
      "required": [
        "exporterId",
        "name"
      ]
    },
    "UserMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserMaster",
      "type": "object",
      "description": "Represents a user of the application.",
      "properties": {
        "userName": {
          "type": "string",
          "description": "User's name."
        },
        "profileId": {
          "type": "string",
          "description": "Reference to Profile. (Relationship: Profile 1:N UserMaster)"
        }
      },
      "required": [
        "userName",
        "profileId"
      ]
    },
    "Profile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Profile",
      "type": "object",
      "description": "Represents a user profile with access permissions.",
      "properties": {
        "profileId": {
          "type": "string",
          "description": "Unique identifier for the profile."
        },
        "name": {
          "type": "string",
          "description": "Name of the profile."
        },
        "modulesAccess": {
          "type": "array",
          "description": "List of module names the profile has access to.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "profileId",
        "name",
        "modulesAccess"
      ]
    },
    "ReceptionLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ReceptionLot",
      "type": "object",
      "description": "Represents a reception lot of fruit.",
      "properties": {
        "lotId": {
          "type": "string",
          "description": "Unique identifier for the lot."
        },
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier (e.g., PROD-DOC123)."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the selected Exporter."
        },
        "producerId": {
          "type": "string",
          "description": "Reference to the selected Producer."
        },
        "document": {
          "type": "string",
          "description": "Document number for the lot."
        },
        "variety": {
          "type": "string",
          "description": "Variety of the fruit."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in the lot."
        },
        "toteCount": {
          "type": "number",
          "description": "Number of totes in the lot."
        },
        "emptyTotes": {
          "type": "number",
          "description": "Optional number of empty totes."
        },
        "noTotes": {
            "type": "number"
        },
        "status": {
          "type": "string",
          "description": "Status of the lot (e.g., 'Pendiente de Peso')."
        },
        "totalWeight": {
          "type": "number",
          "description": "Total weight of the lot."
        },
        "preHydroTemp": {
          "type": "number",
          "description": "Pre-Hidrocooler temperature."
        },
        "postHydroTemp": {
          "type": "number",
          "description": "Post-Hidrocooler temperature."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot was created."
        }
      },
      "required": [
        "displayLotId",
        "exporterId",
        "producerId",
        "document",
        "variety",
        "binCount",
        "toteCount",
        "status",
        "createdAt"
      ]
    },
    "HidrocoolerLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "HidrocoolerLot",
      "type": "object",
      "description": "Represents a lot in the hidrocooler process.",
      "properties": {
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier, same as in ReceptionLot."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in the lot."
        },
        "status": {
          "type": "string",
          "description": "Status of the lot in the hidrocooler (e.g., 'Pendiente de Pre-Hidro', 'En Proceso', 'Finalizado')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot entered the hidrocooler process."
        }
      },
      "required": [
        "displayLotId",
        "producerShortName",
        "binCount",
        "status",
        "createdAt"
      ]
    },
    "Hidrocooler": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Hidrocooler",
      "type": "object",
      "description": "Represents a hidrocooler unit.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the hidrocooler (e.g., HIDROCOOLER 1)."
        },
        "binCount": {
          "type": "number",
          "description": "The default number of bins to process."
        }
      },
      "required": [
        "name",
        "binCount"
      ]
    },
    "ProcessingLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProcessingLot",
      "type": "object",
      "description": "Represents a fraction of a lot being processed in a hidrocooler.",
      "properties": {
        "originalLotId": {
          "type": "string",
          "description": "The ID of the original lot in hidrocoolerLots."
        },
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in this processing fraction."
        },
        "hidrocooler": {
          "type": "string",
          "description": "The hidrocooler unit used (e.g., 'HIDROCOOLER 1')."
        },
        "status": {
          "type": "string",
          "enum": [
            "En Proceso",
            "Finalizado"
          ],
          "description": "Status of the processing fraction."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when processing started."
        }
      },
      "required": [
        "originalLotId",
        "displayLotId",
        "producerShortName",
        "binCount",
        "hidrocooler",
        "status",
        "createdAt"
      ]
    },
    "ChamberLot": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ChamberLot",
      "type": "object",
      "description": "Represents a lot stored in a cooling chamber.",
      "properties": {
        "displayLotId": {
          "type": "string",
          "description": "User-friendly lot identifier."
        },
        "exporterId": {
          "type": "string",
          "description": "Reference to the selected Exporter."
        },
        "producerShortName": {
          "type": "string",
          "description": "Short name of the producer."
        },
        "binCount": {
          "type": "number",
          "description": "Number of bins in this portion of the lot."
        },
        "variety": {
          "type": "string",
          "description": "Variety of the fruit."
        },
        "hidrocooler": {
          "type": "string",
          "description": "The hidrocooler unit used for processing."
        },
        "chamberId": {
          "type": "string",
          "description": "The identifier of the chamber where the lot is stored."
        },
        "coordinate": {
            "type": "string",
            "description": "The specific coordinate within the chamber (e.g., 'A1')."
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente por Almacenar", "Almacenado", "Despachado"],
          "description": "Status of the lot in the chamber."
        },
        "storedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the lot was moved to the chamber module."
        }
      },
      "required": [
        "displayLotId",
        "exporterId",
        "producerShortName",
        "binCount",
        "variety",
        "hidrocooler",
        "status",
        "storedAt"
      ]
    },
    "Chamber": {
