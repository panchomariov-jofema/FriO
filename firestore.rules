/**
 * # Firestore Security Rules for FrigoManager
 *
 * ## Core Philosophy
 * This ruleset establishes a secure-but-permissive model for the development phase.
 * The primary security posture is that ANY authenticated user can perform ANY operation
 * (read, write, delete) on ANY collection. This is intentionally open to facilitate
 * rapid development and testing without permission-related interruptions.
 *
 * ## Data Structure
 * The data is organized into several top-level collections, each representing a distinct
 * entity (e.g., /exporters, /producers, /receptionLots). This flat hierarchy simplifies
 * the security rules significantly.
 *
 * ## Key Security Decision
 * - **Authenticated Access Only**: All operations are gated by a single function, `isSignedIn()`,
 *   which simply checks if a user is authenticated with Firebase Auth (`request.auth != null`).
 *   Anonymous users have no access.
 * - **Full Permissions for Authenticated Users**: If a user is signed in, they are granted
 *   full read and write permissions across all specified collections.
 *
 * ## WARNING: Production Insecurity
 * This ruleset is NOT secure for a production environment. Allowing any authenticated user
 * to write to any collection poses a significant security risk. Before going to production,
 * these rules MUST be replaced with a more granular, role-based access control system.
 * For example, only users with an 'admin' role should be able to write to master data collections.
 *
 * ## Forced Redeployment Timestamp
 * A timestamp is included to force the Firebase CLI to recognize changes and redeploy the rules,
 * bypassing any potential caching issues that might prevent updates from applying.
 * Force redeploy: 1722442939.914282
 */
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    /**
     * isSignedIn()
     * Checks if the user is authenticated via Firebase Auth.
     * @returns {boolean} True if a user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    // ------------------------------------------------------------------------
    // Master Data Collections
    // ------------------------------------------------------------------------

    /**
     * @description Master data collections. Open access for any signed-in user during development.
     * @paths /exporters/{docId}, /producers/{docId}, /binMaterials/{docId}, /otherClients/{docId}, /packagingMaster/{docId}, /usersMaster/{docId}, /profiles/{docId}, /packings/{docId}
     * @allow Authenticated users can read and write freely.
     */
    match /{collection}/{docId} where collection in ['exporters', 'producers', 'binMaterials', 'otherClients', 'packagingMaster', 'usersMaster', 'profiles', 'packings'] {
      allow read, write: if isSignedIn();
    }

    // ------------------------------------------------------------------------
    // Operational Data Collections
    // ------------------------------------------------------------------------

     /**
     * @description Collections for bin and material stock and movements.
     * @paths /binMaterialMovements/{docId}, /binMaterialStock/{docId}
     * @allow Authenticated users can read and write freely.
     */
    match /{collection}/{docId} where collection in ['binMaterialMovements', 'binMaterialStock'] {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Collection for fruit reception lots.
     * @path /receptionLots/{lotId}
     * @allow Any authenticated user can create, read, and update lots.
     */
    match /receptionLots/{lotId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Collection for lots that are pending to enter the hidrocooler process.
     * @path /hidrocoolerLots/{lotId}
     * @allow Any authenticated user can create, read, and update lots.
     */
    match /hidrocoolerLots/{lotId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Collection for lot fractions currently being processed in a hidrocooler.
     * @path /processingLots/{lotId}
     * @allow Any authenticated user can create, read, and update lots.
     */
    match /processingLots/{lotId} {
        allow read, write: if isSignedIn();
    }

    /**
     * @description Collection for lots stored in cooling chambers.
     * @path /chamberLots/{lotId}
     * @allow Any authenticated user can create, read, and update lots.
     */
    match /chamberLots/{lotId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Collection for dispatch records.
     * @path /dispatches/{dispatchId}
     * @allow Any authenticated user can create, read, and update dispatches.
     */
    match /dispatches/{dispatchId} {
      allow read, write: if isSignedIn();
    }
    
    /**
     * @description Collection for packaging reception records.
     * @path /packagingReceptions/{receptionId}
     * @allow Any authenticated user can create, read, and update records.
     */
    match /packagingReceptions/{receptionId} {
        allow read, write: if isSignedIn();
    }

    /**
     * @description Collection for fruit reception from other clients.
     * @path /otherFruitReceptions/{receptionId}
     * @allow Any authenticated user can create, read, and update records.
     */
    match /otherFruitReceptions/{receptionId} {
        allow read, write: if isSignedIn();
    }

    /**
     * @description Collection for packaging movement records.
     * @path /packagingMovements/{movementId}
     * @allow Any authenticated user can create, read, and update records.
     */
    match /packagingMovements/{movementId} {
      allow read, write: if isSignedIn();
    }
  }
}
